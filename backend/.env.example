# Copy this file to .env and fill in the production values before running Docker Compose.

POSTGRES_DB=api_monitoring
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

RABBITMQ_DEFAULT_USER=api_user
RABBITMQ_DEFAULT_PASS=change_me
RABBITMQ_DEFAULT_VHOST=api_monitoring
RABBITMQ_URL=amqp://api_user:change_me@rabbitmq:5672/api_monitoring
RABBITMQ_QUEUE=api_hits

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me

PG_DATABASE=api_monitoring
PG_USER=postgres
PG_PASSWORD=change_me

JWT_SECRET=change_me_to_a_long_random_secret